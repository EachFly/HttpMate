<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.jeraxxxxxxx.httpmate</id>
    <name>HttpMate</name>
    <vendor url="https://github.com/EachFly/HttpMate">jeraxxxxxxx</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <actions>
        <group id="com.github.jeraxxxxxxx.httpmate.HttpMateGroup"
               text="HttpMate"
               description="HttpMate REST API tools"
               icon="/icons/httpmate.svg"
               popup="true">

            <action id="com.github.jeraxxxxxxx.httpmate.actions.RestApiSearchAction"
                    class="com.github.jeraxxxxxxx.httpmate.actions.RestApiSearchAction"
                    text="Search REST APIs"
                    description="Search for REST APIs in the project"
                    icon="/icons/httpmate.svg">
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl BACK_SLASH"/>
                <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt H"/>
            </action>

            <separator/>

            <action id="com.github.jeraxxxxxxx.httpmate.actions.GenerateJsonAction"
                    class="com.github.jeraxxxxxxx.httpmate.actions.GenerateJsonAction"
                    text="Generate JSON"
                    description="Generate JSON for the selected class"/>

            <action id="com.github.jeraxxxxxxx.httpmate.actions.GenerateMockJsonAction"
                    class="com.github.jeraxxxxxxx.httpmate.actions.GenerateMockJsonAction"
                    text="Generate Mock JSON"
                    description="Generate JSON with mock data for the selected class"/>

            <separator/>

            <action id="com.github.jeraxxxxxxx.httpmate.actions.GenerateDocAction"
                    class="com.github.jeraxxxxxxx.httpmate.actions.GenerateDocAction"
                    text="Generate API Doc"
                    description="Generate Markdown documentation for the selected method"/>

            <separator/>

            <action id="com.github.jeraxxxxxxx.httpmate.actions.CodeLineStatisticsAction"
                    class="com.github.jeraxxxxxxx.httpmate.actions.CodeLineStatisticsAction"
                    text="Code Line Statistics"
                    description="Count lines of code, comments, and blanks in the selected directory"
                    icon="/icons/httpmate.svg"/>

            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
        </group>

        <action id="com.github.jeraxxxxxxx.httpmate.actions.RestApiSearchAction.ToolsMenu"
                class="com.github.jeraxxxxxxx.httpmate.actions.RestApiSearchAction"
                text="Search REST APIs"
                description="Search for REST APIs in the project"
                icon="/icons/httpmate.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

    </actions>
</idea-plugin>
